{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/bridge/v0.2/adapter/mode-command.schema.json",
  "title": "Bridge Mode Command",
  "description": "Administrative burn or restore command. Burn and restore commands are expected to be dual-authorized.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "operation",
    "command_id",
    "trace",
    "requested_by",
    "reason_code",
    "approval_mode",
    "approval_evidence"
  ],
  "properties": {
    "version": {
      "const": "0.2"
    },
    "operation": {
      "type": "string",
      "enum": [
        "burn",
        "restore"
      ]
    },
    "command_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "trace": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "requested_by": {
      "type": "string",
      "minLength": 3,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@/-]{2,255}$"
    },
    "reason_code": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "cut_set": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 256
      },
      "uniqueItems": true
    },
    "approval_mode": {
      "type": "string",
      "enum": [
        "dual"
      ]
    },
    "approval_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "quorum",
        "approvers"
      ],
      "properties": {
        "quorum": {
          "type": "integer",
          "minimum": 1,
          "maximum": 16
        },
        "approvers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "role",
              "approved_at"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 3,
                "maxLength": 256,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@/-]{2,255}$"
              },
              "role": {
                "type": "string",
                "minLength": 1,
                "maxLength": 64
              },
              "approved_at": {
                "type": "string",
                "format": "date-time"
              },
              "authn_strength": {
                "type": "string",
                "enum": [
                  "aal2",
                  "aal3",
                  "hardware",
                  "service"
                ]
              }
            }
          },
          "uniqueItems": true
        },
        "ticket": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "basis": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        }
      }
    },
    "ticket": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    }
  }
}